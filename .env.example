# ----------------------------------------------------------------------------
# Copy this file to ".env" and adjust values. NEVER commit the real .env.
#   cp .env.example .env
# ----------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=inventory

# --- Backend ---
# Host port the backend API is published on.
BACKEND_PORT=8000
# Comma-separated origins allowed to call the API (the frontend URL).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Products at/below this stock level are flagged as "low stock".
LOW_STOCK_THRESHOLD=10

# --- Frontend ---
# Host port the frontend is served on.
FRONTEND_PORT=3000
# Backend base URL the browser calls (must be reachable from the browser).
# For local docker-compose this is the published backend port on localhost.
VITE_API_URL=http://localhost:8000
